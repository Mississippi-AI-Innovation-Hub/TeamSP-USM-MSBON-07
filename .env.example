# MSBON Environment Configuration
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real credentials.

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# API Gateway base URL (output from CDK deploy)
VITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com

# ── AWS (CDK / CLI) ──────────────────────────────────────────────────────────
# Set via `aws configure` or IAM role — do NOT hardcode here
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ── CDK Context ──────────────────────────────────────────────────────────────
# Deployment environment name (used to name resources: dev, staging, prod)
CDK_ENV=dev

# ── Lambda Environment (injected automatically by CDK) ───────────────────────
# These are set by CDK stacks — listed here for documentation only.
# TRANSCRIPT_BUCKET=msbon-transcripts-dev
# TRANSCRIPTS_TABLE=msbon-transcripts-dev
# VERIFICATIONS_TABLE=msbon-verifications-dev
# REVIEWS_TABLE=msbon-reviews-dev
# AUDIT_TABLE=msbon-audit-log-dev
# STATE_MACHINE_ARN=arn:aws:states:us-east-1:ACCOUNT_ID:stateMachine:msbon-verification-dev
# ENV=dev
